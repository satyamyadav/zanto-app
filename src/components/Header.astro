---
import { SITE, href } from "../lib/site";
---

<header class="sticky top-0 z-30 border-b border-line/70 backdrop-blur supports-[backdrop-filter]:bg-ink/60">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-5 py-3.5">
    <a href={href("/")} class="flex items-center gap-2 font-semibold tracking-tight">
      <span class="grid size-6 place-items-center rounded-md bg-accent/20 text-accent">◆</span>
      {SITE.name}
    </a>
    <nav class="flex items-center gap-5 text-sm text-white/70">
      <a class="hover:text-white" href={href("/#features")}>Features</a>
      <a class="hover:text-white" href={href("/blog")}>Blog</a>
      <a class="hover:text-white" href={SITE.repo} target="_blank" rel="noopener">GitHub</a>
      <a
        class="rounded-lg bg-accent px-3 py-1.5 font-medium text-white shadow-sm transition-colors hover:bg-accent/90"
        href={href("/download")}
      >
        Download
      </a>
    </nav>
  </div>
</header>

---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
import { href } from "../../lib/site";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---

<Base title="Blog">
  <section class="mx-auto max-w-3xl px-5 pt-20 pb-10">
    <h1 class="text-4xl font-semibold tracking-tight">Blog</h1>
    <ul class="mt-10 space-y-6">
      {posts.map((post) => (
        <li class="rounded-2xl border border-line bg-ink-2/60 p-6 transition-colors hover:border-accent/40">
          <a href={href(`/blog/${post.id}`)} class="block">
            <time class="text-xs text-white/40">{fmt(post.data.date)}</time>
            <h2 class="mt-1 text-xl font-semibold tracking-tight">{post.data.title}</h2>
            <p class="mt-2 text-sm text-white/55">{post.data.description}</p>
            <span class="mt-3 inline-block text-sm text-accent">Read →</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Base>
